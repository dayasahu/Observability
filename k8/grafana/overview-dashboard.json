{
  "title": "Service Health Overview",
  "uid": "service-overview",
  "tags": ["overview","ops","noc"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from":"now-30m","to":"now"},
  "panels": [
    {"id":1,"gridPos":{"x":0,"y":0,"w":24,"h":1},"type":"text","title":"","options":{"mode":"markdown","content":"# 🟢 MyOrg Microservices — Live Health Status"}},
    {
      "id":2,"gridPos":{"x":0,"y":1,"w":4,"h":4},"type":"stat","title":"employee",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value_and_name"},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":1,"color":"green"}]}}},
      "targets":[{"expr":"up{job=\"spring-services\",app=\"employee\"}","legendFormat":"employee"}]
    },
    {
      "id":3,"gridPos":{"x":4,"y":1,"w":4,"h":4},"type":"stat","title":"department",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":1,"color":"green"}]}}},
      "targets":[{"expr":"up{job=\"spring-services\",app=\"department\"}","legendFormat":"department"}]
    },
    {
      "id":4,"gridPos":{"x":8,"y":1,"w":4,"h":4},"type":"stat","title":"apigateway",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":1,"color":"green"}]}}},
      "targets":[{"expr":"up{job=\"spring-services\",app=\"apigateway\"}","legendFormat":"apigateway"}]
    },
    {
      "id":5,"gridPos":{"x":12,"y":1,"w":4,"h":4},"type":"stat","title":"configserver",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":1,"color":"green"}]}}},
      "targets":[{"expr":"up{job=\"spring-services\",app=\"configserver\"}","legendFormat":"configserver"}]
    },
    {
      "id":6,"gridPos":{"x":16,"y":1,"w":4,"h":4},"type":"stat","title":"auth-service",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":1,"color":"green"}]}}},
      "targets":[{"expr":"up{job=\"spring-services\",app=\"auth-service\"}","legendFormat":"auth-service"}]
    },
    {
      "id":7,"gridPos":{"x":20,"y":1,"w":4,"h":4},"type":"stat","title":"All Services UP",
      "options":{"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig":{"defaults":{"mappings":[{"type":"value","options":{"5":{"text":"ALL UP ✅","color":"green"}}}],"thresholds":{"steps":[{"value":0,"color":"red"},{"value":5,"color":"green"}]}}},
      "targets":[{"expr":"sum(up{job=\"spring-services\"})","legendFormat":""}]
    },
    {
      "id":8,"gridPos":{"x":0,"y":5,"w":24,"h":8},"type":"timeseries",
      "title":"Request Rate — All Services",
      "fieldConfig":{"defaults":{"unit":"reqps","custom":{"fillOpacity":5}}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["lastNotNull","mean","max"]}},
      "targets":[{"expr":"sum by (app) (rate(http_server_requests_seconds_count{job=\"spring-services\",uri!~\"/actuator.*\"}[1m]))","legendFormat":"{{app}}"}]
    },
    {
      "id":9,"gridPos":{"x":0,"y":13,"w":12,"h":8},"type":"timeseries",
      "title":"Error Rate — All Services",
      "fieldConfig":{"defaults":{"unit":"percent","custom":{"fillOpacity":10}}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["lastNotNull","max"]}},
      "targets":[{"expr":"100 * sum by (app) (rate(http_server_requests_seconds_count{job=\"spring-services\",status=~\"[45]..\",uri!~\"/actuator.*\"}[1m])) / sum by (app) (rate(http_server_requests_seconds_count{job=\"spring-services\",uri!~\"/actuator.*\"}[1m]))","legendFormat":"{{app}}"}]
    },
    {
      "id":10,"gridPos":{"x":12,"y":13,"w":12,"h":8},"type":"timeseries",
      "title":"P95 Response Time — All Services",
      "fieldConfig":{"defaults":{"unit":"ms"}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["lastNotNull","max"]}},
      "targets":[{"expr":"histogram_quantile(0.95, sum by (app,le) (rate(http_server_requests_seconds_bucket{job=\"spring-services\",uri!~\"/actuator.*\"}[2m]))) * 1000","legendFormat":"{{app}}"}]
    },
    {
      "id":11,"gridPos":{"x":0,"y":21,"w":12,"h":8},"type":"timeseries",
      "title":"JVM Heap — All Services",
      "fieldConfig":{"defaults":{"unit":"bytes"}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["lastNotNull"]}},
      "targets":[{"expr":"sum by (app) (jvm_memory_used_bytes{job=\"spring-services\",area=\"heap\"})","legendFormat":"{{app}}"}]
    },
    {
      "id":12,"gridPos":{"x":12,"y":21,"w":12,"h":8},"type":"timeseries",
      "title":"CPU Usage — All Services",
      "fieldConfig":{"defaults":{"unit":"percentunit"}},
      "options":{"legend":{"displayMode":"table","placement":"right","calcs":["lastNotNull","max"]}},
      "targets":[{"expr":"process_cpu_usage{job=\"spring-services\"}","legendFormat":"{{app}}"}]
    }
  ]
}
